# --- 请求 (Request) ---
# 起点坐标 (由解释器提供，确保坐标统一)
float64 start_x
float64 start_y
float64 start_z

# 终点坐标
float64 x
float64 y
float64 z

# 运动参数
float64 velocity       # 单位: m/s (或 mm/s，取决于你的设定)
float64 sample_time    # 采样周期，例如 0.02s

---
# --- 响应 (Response) ---
bool success           # 是否成功到达
string message         # 状态描述 (如 "求解失败" 或 "被用户中止")
float64 travel_time    # 实际运动耗时